generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model categories {
  catid            String   @id
  parent_catid     String
  name             String
  display_name     String
  image            String
  unselected_image String
  selected_image   String
  level            Int
  created_at       DateTime @default(now())
  updated_at       DateTime
}

model products {
  id               String   @id
  link             String
  name             String
  price            Float
  comm_rate        Float
  comm             Float
  sold             Int
  type             String
  shop_id          String
  created_at       DateTime @default(now())
  updated_at       DateTime
  live_start       BigInt?
  live_end         BigInt?
  flash_sale_start BigInt?
  flash_sale_end   BigInt?
  shops            shops    @relation(fields: [shop_id], references: [id])
}

model shops {
  id       String     @id
  products products[]
}

model user {
  id        String    @id
  username  String
  cookie    String
  status    Int
  table     Int
  revenue   Float
  comm      Float
  createdAt DateTime  @default(now())
  updatedAt DateTime
  deletedAt DateTime?
}
